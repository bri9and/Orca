#!/usr/bin/env bash
set -euo pipefail

# в”Җв”Җв”Җ Jarvis вҖ” AI Agent Workspace в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Standalone launcher for the Jarvis dashboard
# Usage: jarvis [--port PORT] [--no-open] [--build] [--help]
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
DASHBOARD_DIR="$ROOT_DIR/dashboard"
PORT=3001
OPEN_BROWSER=true
MODE="dev"

# в”Җв”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

print_banner() {
  echo ""
  echo -e "${CYAN}${BOLD}    в•Ұв•”в•җв•—в•Ұв•җв•—в•Ұ  в•Ұв•Ұв•”в•җв•—${NC}"
  echo -e "${CYAN}${BOLD}    в•‘в• в•җв•Јв• в•Ұв•қв•ҡв•—в•”в•қв•‘в•ҡв•җв•—${NC}"
  echo -e "${CYAN}${BOLD}   в•ҡв•қв•© в•©в•©в•ҡв•җ в•ҡв•қ в•©в•ҡв•җв•қ${NC}"
  echo -e "${BLUE}  AI Agent Workspace v2.0${NC}"
  echo ""
}

usage() {
  echo "Usage: jarvis [OPTIONS]"
  echo ""
  echo "Options:"
  echo "  --port PORT    Port to run on (default: 3001)"
  echo "  --no-open      Don't open browser automatically"
  echo "  --build        Build for production first"
  echo "  --prod         Run in production mode (requires build)"
  echo "  --help         Show this help message"
  echo ""
  echo "Examples:"
  echo "  jarvis                  Start dev server on port 3001"
  echo "  jarvis --port 8080      Start on port 8080"
  echo "  jarvis --build --prod   Build and run production server"
}

# в”Җв”Җв”Җ Parse args в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
while [[ $# -gt 0 ]]; do
  case $1 in
    --port)
      PORT="$2"
      shift 2
      ;;
    --no-open)
      OPEN_BROWSER=false
      shift
      ;;
    --build)
      MODE="build"
      shift
      ;;
    --prod)
      MODE="prod"
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo -e "${RED}Unknown option: $1${NC}"
      usage
      exit 1
      ;;
  esac
done

# в”Җв”Җв”Җ Preflight checks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
print_banner

# Check Node.js
if ! command -v node &> /dev/null; then
  echo -e "${RED}Error: Node.js is not installed.${NC}"
  echo "Install it from https://nodejs.org or via: brew install node"
  exit 1
fi

NODE_VERSION=$(node -v | sed 's/v//' | cut -d. -f1)
if [[ "$NODE_VERSION" -lt 18 ]]; then
  echo -e "${RED}Error: Node.js 18+ required (found v$(node -v))${NC}"
  exit 1
fi

# Check dashboard directory
if [[ ! -d "$DASHBOARD_DIR" ]]; then
  echo -e "${RED}Error: Dashboard not found at $DASHBOARD_DIR${NC}"
  echo "Run: git submodule update --init"
  exit 1
fi

# Check for .env.local
if [[ ! -f "$DASHBOARD_DIR/.env.local" ]]; then
  echo -e "${YELLOW}Warning: No .env.local found in dashboard/${NC}"
  if [[ -f "$ROOT_DIR/.env.local.example" ]]; then
    echo -e "  Copy the example: ${BOLD}cp .env.local.example dashboard/.env.local${NC}"
  fi
  echo -e "  Chat features require ${BOLD}ANTHROPIC_API_KEY${NC} to be set."
  echo ""
fi

# Install dependencies if needed
if [[ ! -d "$DASHBOARD_DIR/node_modules" ]]; then
  echo -e "${YELLOW}Installing dependencies...${NC}"
  (cd "$DASHBOARD_DIR" && npm install)
  echo ""
fi

# в”Җв”Җв”Җ Clean stale locks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ -f "$DASHBOARD_DIR/.next/dev/lock" ]]; then
  echo -e "${YELLOW}Removing stale lock file...${NC}"
  rm -f "$DASHBOARD_DIR/.next/dev/lock"
fi

# в”Җв”Җв”Җ Launch в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
cleanup() {
  echo ""
  echo -e "${CYAN}Jarvis shutting down...${NC}"
  kill 0 2>/dev/null
  exit 0
}
trap cleanup SIGINT SIGTERM

case $MODE in
  build)
    echo -e "${BLUE}Building for production...${NC}"
    (cd "$DASHBOARD_DIR" && npm run build)
    echo -e "${GREEN}Build complete!${NC}"
    echo -e "Run ${BOLD}jarvis --prod${NC} to start the production server."
    exit 0
    ;;
  prod)
    if [[ ! -d "$DASHBOARD_DIR/.next" ]]; then
      echo -e "${YELLOW}No build found. Building first...${NC}"
      (cd "$DASHBOARD_DIR" && npm run build)
    fi
    echo -e "${GREEN}Starting Jarvis (production) on port ${PORT}...${NC}"
    echo -e "${BOLD}  http://localhost:${PORT}${NC}"
    echo ""

    if [[ "$OPEN_BROWSER" == true ]]; then
      (sleep 2 && open "http://localhost:${PORT}") &
    fi

    cd "$DASHBOARD_DIR" && npx next start --port "$PORT"
    ;;
  dev)
    echo -e "${GREEN}Starting Jarvis on port ${PORT}...${NC}"
    echo -e "${BOLD}  http://localhost:${PORT}${NC}"
    echo ""
    echo -e "  ${BLUE}Agents:${NC}  5 loaded (planner, coder, researcher, reviewer, writer)"
    echo -e "  ${BLUE}Skills:${NC}  5 loaded (/plan, /search-first, /code-review, /tdd, /cost-aware)"
    echo -e "  ${BLUE}Models:${NC}  Claude Sonnet | Gemini | GPT-4o | Claude Opus"
    echo ""
    echo -e "  Press ${BOLD}Ctrl+C${NC} to stop"
    echo ""

    if [[ "$OPEN_BROWSER" == true ]]; then
      (sleep 3 && open "http://localhost:${PORT}") &
    fi

    cd "$DASHBOARD_DIR" && npx next dev --port "$PORT"
    ;;
esac
