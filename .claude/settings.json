{
  "enabledPlugins": {
    "fullstack-dev-skills@fullstack-dev-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/pre-tool-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/post-edit-verify.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
